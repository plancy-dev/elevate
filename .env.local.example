# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_PROJECT_ID=your-project-ref

# Server-only: never expose to the browser or client bundles
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cursor MCP: Supabase — create at https://supabase.com/dashboard/account/tokens
# (Personal Access Token — NOT the service_role JWT)
SUPABASE_ACCESS_TOKEN=

# Optional: Google Stitch MCP (design prototyping)
# STITCH_GOOGLE_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Elevate

# Optional: Google AI (future features)
# GEMINI_API_KEY=

# One-off: pnpm run db:seed-admin (creates admin user via Auth API — do not commit real passwords)
# ADMIN_EMAIL=admin@yourcompany.com
# ADMIN_PASSWORD=
